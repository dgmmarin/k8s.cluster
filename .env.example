# Copy to .env (gitignored) — mise loads it automatically (see mise.toml).

# ── Provider ─────────────────────────────────────────────────────────────────
# Pick ONE path:
#
#   Hetzner Cloud (creates the server for you): set HCLOUD_TOKEN, run
#     `mise run provision`.
#   Bring-your-own VPS, e.g. netcup (server already exists): set SERVER_IP,
#     run `mise run provision-netcup`. HCLOUD_TOKEN not needed.

# Hetzner Cloud API token (project → Security → API Tokens, read+write).
# Only for the Hetzner path.
HCLOUD_TOKEN=

# Public IP of your existing VPS. Only for the netcup/bring-your-own path.
# The host firewall (ufw) is configured on the node itself, since netcup has
# no cloud firewall API.
SERVER_IP=

# ── Firewall / dynamic IP ────────────────────────────────────────────────────
# Allowlisted IP for SSH (22) and kube-api (6443).
# LEAVE EMPTY to auto-detect your current public IP at playbook run time —
# with a dynamic IP run `mise run firewall` (Hetzner) or
# `mise run netcup-firewall` (netcup/BYO) whenever your IP changes.
#
# ⚠ netcup caveat: a wrong/rotated IP locks you out at the host firewall and
# there is no cloud API to fix it remotely — recover via the netcup web
# console (VNC), then re-run netcup-firewall. Consider a static IP.
ADMIN_IP=

# ── GitHub (only needed if the repos are private) ────────────────────────────
GITHUB_ORG=dgmmarin
GITHUB_TOKEN=

# ── Optional overrides (defaults shown) ──────────────────────────────────────
#HCLOUD_SERVER_NAME=k3s-1
#HCLOUD_SERVER_TYPE=cpx31        # 4 vCPU / 8 GB / 160 GB (~€15/mo)
#HCLOUD_LOCATION=nbg1            # nbg1 | fsn1 | hel1
#HCLOUD_IMAGE=ubuntu-24.04
#SSH_PUBLIC_KEY_FILE=/home/you/.ssh/id_ed25519.pub
#K3S_VERSION=v1.36.2+k3s1
#DOMAIN=k8s.bitulzero.ro
#GRAFANA_ADMIN_PASSWORD=         # random if empty (printed once at bootstrap)
